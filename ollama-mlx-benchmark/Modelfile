FROM qwen3.5:35b-a3b-coding-nvfp4

# Context window — Ollama's HTTP API and many clients default to a small
# effective context. 65536 is the sweet spot for agentic coding.
# The model itself natively supports 262144 — push higher if your RAM allows.
PARAMETER num_ctx 65536

# No output cap — let tool-call chains finish without truncation.
PARAMETER num_predict -1

# Sampling — Qwen 3.5 model card defaults.
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER repeat_penalty 1.0
